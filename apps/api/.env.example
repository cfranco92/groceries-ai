# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5433/groceries_ai

# ─── Firebase Auth ────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── GCP ──────────────────────────────────────────────
GCP_PROJECT_ID=
GCS_BUCKET_NAME=groceries-ai-receipts
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Google Document AI ──────────────────────────────
# 1. Go to GCP Console > Document AI > Processors
# 2. Create a processor using the "Expense Parser" type
# 3. Copy the processor ID and set it below
# 4. Authentication uses GOOGLE_APPLICATION_CREDENTIALS (service account key JSON)
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
GOOGLE_DOCUMENT_AI_LOCATION=us

# ─── Server ───────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Redis (Phase 2+) ────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
