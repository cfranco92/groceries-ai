{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$CLAUDE_FILE_PATHS\" ] && npx prettier --write $CLAUDE_FILE_PATHS || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm lint || true"
          }
        ]
      }
    ]
  }
}
