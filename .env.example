# =============================================================================
# GroceriesAI — Root Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# This file is used by scripts/jira.sh and shared across all agents.
# NEVER commit the .env file — only .env.example.
# =============================================================================

# Jira Integration (for Claude Code agents)
# Get your API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://fcode.atlassian.net
JIRA_EMAIL=cfrancobedoya@gmail.com
JIRA_API_TOKEN=

# GitHub (optional — gh CLI uses its own auth)
GITHUB_REPO=
